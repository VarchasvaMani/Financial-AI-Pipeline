# ── Core ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DB_PATH=data/pipeline.db
LOG_LEVEL=INFO
DEFAULT_WATCHLIST=AAPL,MSFT,GOOGL,NVDA,TSLA,AMZN,META,JPM,GS,SPY

# ── Data Sources (all free tiers available) ───────────
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key   # alphavantage.co
POLYGON_API_KEY=your_polygon_key               # polygon.io (live stream)

# ── Alerts ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token     # @BotFather on Telegram
TELEGRAM_CHAT_ID=your_chat_id                  # your personal or group chat ID
SLACK_WEBHOOK_URL=https://hooks.slack.com/...  # Slack incoming webhook URL

# ── Paper Trading ─────────────────────────────────────
PAPER_INITIAL_CAPITAL=100000
PAPER_POSITION_SIZE=0.10

# ── Backtest defaults ─────────────────────────────────
BACKTEST_START=2024-01-01
BACKTEST_END=2024-12-31
